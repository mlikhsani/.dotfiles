# APPEARANCE
fontname "Terminus:size=9"
sticky yes
gap 0 10 0 0

borderwidth 1
color activeborder '#ffffff'
color inactiveborder '#222222'

# APPLICATION MENU (as powermenu)
command     browser         qutebrowser
command     terminal        alacritty
command     "file manager"  pcmanfm
command     webcam          webcam.sh
command     " "             ""
command     "shutdown"      poweroff
command     "restart"       "shutdown -r now"

# IGNORE
ignore "dzen title"

# MOUSE KEYBINDING (1:left, 2:middle, 3:right)
unbind-mouse all
bind-mouse  1       menu-cmd
bind-mouse  4-1     window-move
bind-mouse  4-3     window-resize

# KEYBOARD KEYBINDING
unbind-key  all

bind-key    S4-c    window-close
bind-key    S4-r    restart
bind-key    S4-q    quit
bind-key    S4-f    window-fullscreen
bind-key    4-l     menu-exec
bind-key    4-m     window-maximize
bind-key    4-h     window-cycle
bind-key    4-t     window-rcycle
bind-key    4-Tab   group-last
bind-key    4-1     group-only-1
bind-key    4-2     group-only-2
bind-key    4-3     group-only-3
bind-key    4-4     group-only-4
bind-key    S4-1    window-movetogroup-1
bind-key    S4-2    window-movetogroup-2
bind-key    S4-3    window-movetogroup-3
bind-key    S4-4    window-movetogroup-4

# volume
bind-key    XF86AudioRaiseVolume  "mixer vol.volume=+5%"
bind-key    XF86AudioLowerVolume  "mixer vol.volume=-5%"
bind-key    XF86AudioMute         "mixer vol.mute=toggle"

# brightness (need acpi_video module loaded). Enable if using drm-kmod other than ver 61
bind-key    XF86MonBrightnessUp   "backlight incr 4"
bind-key    XF86MonBrightnessDown "backlight decr 4"

# programs
bind-key    4-Print               "flameshot full -p /home/ikhsan/Pictures/screenshot/"
bind-key    S4-Print              "flameshot gui"
bind-key    S4-Return             alacritty
bind-key    S4-l                  lock_screen.sh

# GROUP
autogroup   1       "Alacritty", "Alacritty"
autogroup   2       "pcmanfm", "Pcmanfm"
autogroup   3       "org.pwmt.zathura", "Zathura"
autogroup   4       "qutebrowser", "qutebrowser"
